# LLM（必填）
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# Database
DATABASE_URL=postgresql+asyncpg://storyflow:storyflow@postgres:5432/storyflow

# Redis
REDIS_URL=redis://redis:6379/0

# 文生图（可选，不配自动 Mock）
IMAGE_API_PROVIDER=dashscope
IMAGE_API_KEY=

# 图生视频（可选，不配自动 FFmpeg 静态视频）
VIDEO_API_PROVIDER=kling
VIDEO_API_KEY=

# TTS 配音（可选，不配自动静默音）
VOICE_API_PROVIDER=dashscope_tts
VOICE_API_KEY=